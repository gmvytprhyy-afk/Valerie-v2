# Discord Bot Token — from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Discord Application (Client) ID — from the same developer portal
CLIENT_ID=your_client_id_here

# Optional: restrict slash command registration to one guild during development
# Leave blank to register commands globally (takes ~1 hour to propagate)
GUILD_ID=your_guild_id_here
